#!/usr/bin/env bash
#
# Project pre-commit checks. The `commit` shell helper runs this by filename from the repo
# root before committing — it is NOT a git hook. Format and lint here; the commit helper
# stages whatever this changes afterward. Exit non-zero to abort the commit.
#
# Add or remove steps to taste (types:check, tests, etc.).
set -euo pipefail

if [ -x vendor/bin/pint ]; then
    echo "▶ pint"
    vendor/bin/pint --dirty
fi

if [ -d node_modules ]; then
    echo "▶ eslint"
    npm run lint

    echo "▶ prettier"
    npm run format
fi
