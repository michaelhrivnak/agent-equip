{
	"name": "agent-equip",
	"version": "0.0.4",
	"description": "Quickstart installer that seeds AI-development tooling into projects, per stack",
	"license": "MIT",
	"author": "Michael Hrivnak",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/michaelhrivnak/agent-equip.git"
	},
	"homepage": "https://github.com/michaelhrivnak/agent-equip#readme",
	"bugs": {
		"url": "https://github.com/michaelhrivnak/agent-equip/issues"
	},
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"files": [
		"dist/",
		"templates/",
		"assets/"
	],
	"bin": {
		"agent-equip": "dist/agent-equip.js"
	},
	"scripts": {
		"start": "bun run bin/agent-equip.ts",
		"stacks": "bun run scripts/generate-stacks.ts",
		"build": "rm -rf dist && bun build bin/agent-equip.ts --target=node --outfile=dist/agent-equip.js --external @clack/prompts --external commander && chmod +x dist/agent-equip.js",
		"prepublishOnly": "bun run build",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"mutate": "stryker run",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint --error-on-warnings ./bin ./src ./test",
		"fix": "biome check --write ./bin ./src ./test"
	},
	"dependencies": {
		"@clack/prompts": "^0.11.0",
		"commander": "^14.0.1",
		"fast-xml-parser": "^5.10.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.5",
		"@stryker-mutator/core": "^9.6.1",
		"@types/bun": "latest",
		"typescript": "^5.9.3"
	}
}
